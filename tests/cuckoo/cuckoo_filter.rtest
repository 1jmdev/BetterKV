@name CF.RESERVE
@group cuckoo
@since 6.2.0

=== TEST: Reserve Cuckoo filter
RUN:
CF.RESERVE mycf 1000 EXPANSION 2
EXPECT:
OK

---

@name CF.ADD
@group cuckoo
@since 6.2.0

=== TEST: Add to cuckoo filter
SETUP:
CF.RESERVE cf:test 1000
RUN:
CF.ADD cf:test "item1"
EXPECT:
(integer) 1

=== TEST: Add duplicate returns 0
SETUP:
CF.RESERVE cf:dups 1000
CF.ADD cf:dups "dup"
RUN:
CF.ADD cf:dups "dup"
EXPECT:
(integer) 0

---

@name CF.ADDNX
@group cuckoo
@since 6.2.0

=== TEST: Add if not exists
SETUP:
CF.RESERVE cf:nx 1000
RUN:
CF.ADDNX cf:nx "new"
EXPECT:
(integer) 1

=== TEST: ADDNX on existing returns 0
SETUP:
CF.RESERVE cf:existing 1000
CF.ADD cf:existing "exists"
RUN:
CF.ADDNX cf:existing "exists"
EXPECT:
(integer) 0

---

@name CF.EXISTS
@group cuckoo
@since 6.2.0

=== TEST: Check if exists
SETUP:
CF.RESERVE cf:check 1000
CF.ADD cf:check "found"
RUN:
CF.EXISTS cf:check "found"
EXPECT:
(integer) 1

=== TEST: Check non-existing
SETUP:
CF.RESERVE cf:missing 1000
RUN:
CF.EXISTS cf:missing "notfound"
EXPECT:
(integer) 0

---

@name CF.DEL
@group cuckoo
@since 6.2.0

=== TEST: Delete from filter
SETUP:
CF.RESERVE cf:del 1000
CF.ADD cf:del "removeme"
RUN:
CF.DEL cf:del "removeme"
EXPECT:
(integer) 1

=== TEST: Delete non-existing returns 0
SETUP:
CF.RESERVE cf:nodelem 1000
RUN:
CF.DEL cf:nodelem "nothere"
EXPECT:
(integer) 0

---

@name CF.INFO
@group cuckoo
@since 6.2.0

=== TEST: Get filter info
SETUP:
CF.RESERVE cf:info 1000
RUN:
CF.INFO cf:info
EXPECT:
(match) .*

---

@name CF.INSERT
@group cuckoo
@since 6.2.0

=== TEST: Insert with auto-reserve
RUN:
CF.INSERT cf:auto CAPACITY 1000 ITEMS "item1" "item2"
EXPECT:
(match) (integer) [0-9]+

---

@name CF.INSERTNX
@group cuckoo
@since 6.2.0

=== TEST: Insert only non-existing
RUN:
CF.INSERTNX cf:autonx CAPACITY 1000 ITEMS "new1" "new2"
EXPECT:
(match) (integer) [0-9]+

---

@name CF.COUNT
@group cuckoo
@since 6.2.0

=== TEST: Count items
SETUP:
CF.RESERVE cf:count 1000
CF.MADD cf:count "a" "b" "c"
RUN:
CF.COUNT cf:count "a"
EXPECT:
(match) (integer) [0-9]+

---

@name CF.MEXISTS
@group cuckoo
@since 6.2.0

=== TEST: Check multiple items
SETUP:
CF.RESERVE cf:mecheck 1000
CF.MADD cf:mecheck "x" "y"
RUN:
CF.MEXISTS cf:mecheck "x" "y" "z"
EXPECT:
1) (integer) 1
2) (integer) 1
3) (integer) 0
