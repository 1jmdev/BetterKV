@name TOPK.RESERVE
@group topk
@since 6.2.0

=== TEST: Reserve top-k
RUN:
TOPK.RESERVE tk1 10
EXPECT:
OK

=== TEST: Reserve with width and depth
RUN:
TOPK.RESERVE tk2 5 1000 5
EXPECT:
OK

---

@name TOPK.ADD
@group topk
@since 6.2.0

=== TEST: Add item
SETUP:
TOPK.RESERVE tk:add 5
RUN:
TOPK.ADD tk:add "item1"
EXPECT:
(any)

=== TEST: Add with increment
SETUP:
TOPK.RESERVE tk:addinc 5
RUN:
TOPK.ADD tk:addinc "item" 5
EXPECT:
(any)

---

@name TOPK.INCRBY
@group topk
@since 6.2.0

=== TEST: Increment item count
SETUP:
TOPK.RESERVE tk:incr 10
TOPK.ADD tk:incr "counter" 1
RUN:
TOPK.INCRBY tk:incr "counter" 9
EXPECT:
(any)

=== TEST: Increment multiple items
SETUP:
TOPK.RESERVE tk:multincr 10
RUN:
TOPK.INCRBY tk:multincr "a" 5 "b" 3
EXPECT:
(match) .*

---

@name TOPK.QUERY
@group topk
@since 6.2.0

=== TEST: Query if item in top-k
SETUP:
TOPK.RESERVE tk:query 3
TOPK.INCRBY tk:query "hot1" 10 "hot2" 8 "cold" 1
RUN:
TOPK.QUERY tk:query "hot1"
EXPECT:
(integer) 1

=== TEST: Query non-top item
SETUP:
TOPK.RESERVE tk:notop 3
TOPK.INCRBY tk:notop "a" 100 "b" 50 "c" 1
RUN:
TOPK.QUERY tk:notop "c"
EXPECT:
(integer) 0

---

@name TOPK.COUNT
@group topk
@since 6.2.0

=== TEST: Get item count
SETUP:
TOPK.RESERVE tk:count 5
TOPK.INCRBY tk:count "item" 42
RUN:
TOPK.COUNT tk:count "item"
EXPECT:
(match) (integer) [0-9]+

---

@name TOPK.LIST
@group topk
@since 6.2.0

=== TEST: List top items
SETUP:
TOPK.RESERVE tk:list 3
TOPK.INCRBY tk:list "a" 5 "b" 10 "c" 3
RUN:
TOPK.LIST tk:list
EXPECT:
(match) .*

=== TEST: List with counts
SETUP:
TOPK.RESERVE tk:listcounts 3
TOPK.INCRBY tk:listcounts "x" 20 "y" 15
RUN:
TOPK.LIST tk:listcounts WITHCOUNTS
EXPECT:
(match) .*

---

@name TOPK.INFO
@group topk
@since 6.2.0

=== TEST: Get top-k info
SETUP:
TOPK.RESERVE tk:info 10
RUN:
TOPK.INFO tk:info
EXPECT:
(match) .*
