@name SLOWLOG GET
@group server
@since 6.2.0

=== TEST: Get slowlog entries
RUN:
SLOWLOG GET
EXPECT:
(match) .*

=== TEST: Get limited slowlog entries
RUN:
SLOWLOG GET 5
EXPECT:
(match) .*

---

@name SLOWLOG LEN
@group server
@since 6.2.0

=== TEST: Get slowlog length
RUN:
SLOWLOG LEN
EXPECT:
(match) (integer) [0-9]+

---

@name SLOWLOG RESET
@group server
@since 6.2.0

=== TEST: Clear slowlog
RUN:
SLOWLOG RESET
EXPECT:
OK

---

@name MODULE LIST
@group server
@since 6.2.0

=== TEST: List loaded modules
RUN:
MODULE LIST
EXPECT:
(match) .*

---

@name MODULE LOAD
@group server
@since 6.2.0

=== TEST: Load module returns OK or error
RUN:
MODULE LOAD "/path/to/module.so"
EXPECT:
(any)

---

@name MODULE UNLOAD
@group server
@since 6.2.0

=== TEST: Unload module returns OK or error
RUN:
MODULE UNLOAD modulename
EXPECT:
(any)

